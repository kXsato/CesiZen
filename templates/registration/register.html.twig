{% extends 'base.html.twig' %}

{% block title %}Créer un compte{% endblock %}

{% block body %}
<div class="hero bg-base-200 flex-1">
    <div class="hero-content flex-col lg:flex-row-reverse">
        <div class="text-center lg:text-left">
            <h1 class="text-5xl font-bold">Créer un compte</h1>
            <p class="py-6 w-2/3">
                Rejoignez CesiZen et accédez à votre espace personnel.
            </p>
        </div>
        <div class="card bg-base-100 w-full max-w-sm shrink-0 shadow-2xl">
            <div class="card-body">
                {{ form_errors(registrationForm) }}

                {{ form_start(registrationForm, {'attr': {'novalidate': 'novalidate'}}) }}
                <fieldset class="fieldset">
                    <label class="label">{{ form_label(registrationForm.email) }}</label>
                    {{ form_widget(registrationForm.email, {'attr': {'class': 'input w-full'}}) }}
                    {{ form_errors(registrationForm.email) }}

                    <label class="label">{{ form_label(registrationForm.userName) }}</label>
                    {{ form_widget(registrationForm.userName, {'attr': {'class': 'input w-full'}}) }}
                    {{ form_errors(registrationForm.userName) }}

                    <label class="label">{{ form_label(registrationForm.birthDate) }}</label>
                    {{ form_widget(registrationForm.birthDate, {'attr': {'class': 'input w-full'}}) }}
                    {{ form_errors(registrationForm.birthDate) }}

                    <label class="label">{{ form_label(registrationForm.plainPassword.first) }}</label>
                    {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'input w-full'}}) }}
                    {{ form_errors(registrationForm.plainPassword.first) }}

                    <label class="label">{{ form_label(registrationForm.plainPassword.second) }}</label>
                    {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'input w-full'}}) }}
                    {{ form_errors(registrationForm.plainPassword.second) }}

                    <div class="flex items-start gap-2 mt-2">
                        {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'checkbox checkbox-sm mt-0.5'}}) }}
                        <span class="text-sm text-base-content/70">
                            J'ai lu et j'accepte les
                            <a href="{{ path('info_page_legal', {slug: 'cgu'}) }}" target="_blank" class="link link-hover font-semibold">CGU</a>
                            et la
                            <a href="{{ path('info_page_legal', {slug: 'politique-de-confidentialite'}) }}" target="_blank" class="link link-hover font-semibold">politique de confidentialité</a>.
                        </span>
                    </div>
                    {{ form_errors(registrationForm.agreeTerms) }}

                    <button type="submit" class="btn btn-neutral mt-4 w-full">Créer mon compte</button>

                    <p class="text-center text-sm mt-4">
                        Déjà un compte ?
                        <a href="{{ path('app_login') }}" class="link link-hover font-semibold">Se connecter</a>
                    </p>
                </fieldset>
                {{ form_end(registrationForm) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
