{% macro menuItemUrl(item) %}
    {%- if item.systemRoute -%}
        {{ path(item.systemRoute) }}
    {%- elseif item.infoPage -%}
        {{ path(item.infoPage.category.value == 'legal' ? 'info_page_legal' : (item.infoPage.category.value == 'root' ? 'info_page_root' : 'info_page'), {slug: item.infoPage.slug}) }}
    {%- else -%}
        {{ item.rawUrl }}
    {%- endif -%}
{% endmacro %}

{% import _self as nav %}

<div class="navbar bg-base-100 shadow-sm">
    <div class="navbar-start">
        <div class="group relative">
            <button class="btn btn-ghost btn-circle">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
                </svg>
            </button>
            <ul class="hidden group-hover:block absolute left-0 top-full bg-base-100 rounded-box shadow w-52 p-2 z-50">
                {% for item in menu_items %}
                    {% if item.children|length > 0 %}
                        <li class="group/sub relative">
                            <a class="flex justify-between items-center">
                                {{ item.label }}
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform group-hover/sub:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                            </a>
                            <ul class="hidden group-hover/sub:block absolute left-0 top-full bg-base-100 rounded-box shadow w-48 p-2 z-50">
                                {% for child in item.children %}
                                    {% if child.isActive %}
                                        <li><a href="{{ nav.menuItemUrl(child) }}">{{ child.label }}</a></li>
                                    {% endif %}
                                {% endfor %}
                            </ul>
                        </li>
                    {% else %}
                        <li><a href="{{ nav.menuItemUrl(item) }}">{{ item.label }}</a></li>
                    {% endif %}
                {% else %}
                    <li><span class="text-gray-400 text-xs p-2">Aucune page disponible</span></li>
                {% endfor %}
            </ul>
        </div>
    </div>
    <div class="navbar-center">
        <a class="btn btn-ghost text-xl">CesiZen</a>
    </div>
    <div class="navbar-end">
        <button class="btn btn-ghost btn-circle">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
        </button>
        {% if app.user %}
            <a href="{{ path('app_logout') }}" class="btn btn-ghost btn-circle">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
            </a>
        {% endif %}
        <a href="{% if app.user %}{% if is_granted('ROLE_ADMIN') %}{{ path('admin') }}{% else %}{{ path('user_dashboard') }}{% endif %}{% else %}{{ path('app_login') }}{% endif %}" class="btn btn-ghost gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A8.966 8.966 0 0112 15c2.347 0 4.496.9 6.121 2.372M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {% if app.user %}
                <span class="text-sm font-medium">{{ app.user.userName }}</span>
            {% endif %}
        </a>
    </div>
</div>
