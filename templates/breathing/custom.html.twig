{% extends 'base.html.twig' %}

{% block title %}Exercice personnalisé — Respiration{% endblock %}

{% block body %}
<div class="flex-1 bg-base-200 flex flex-col items-center justify-center py-12 px-4">
    <div class="text-center mb-8">
        <h1 class="text-3xl font-bold mb-1">Exercice personnalisé</h1>
        <p class="text-base-content/60">Configurez vos durées, puis lancez l'exercice.</p>
    </div>

    <div class="w-full max-w-lg flex flex-col gap-8">

        <!-- Configuration -->
        <div id="config-panel" class="card bg-base-100 shadow-md p-6 flex flex-col gap-6">

            <div class="flex flex-col gap-2">
                <div class="flex justify-between items-center">
                    <label class="font-semibold">Inspiration</label>
                    <span class="badge badge-primary" id="label-inspiration">5s</span>
                </div>
                <input type="range" id="slider-inspiration" min="3" max="15" value="5" step="1" class="range range-primary" />
                <div class="flex justify-between text-xs text-base-content/40 px-1">
                    <span>3s</span><span>15s</span>
                </div>
            </div>

            <div class="flex flex-col gap-2">
                <div class="flex justify-between items-center">
                    <label class="font-semibold">Apnée <span class="text-xs font-normal text-base-content/50">(0 = sans apnée)</span></label>
                    <span class="badge badge-accent" id="label-apnea">0s</span>
                </div>
                <input type="range" id="slider-apnea" min="0" max="10" value="0" step="1" class="range range-accent" />
                <div class="flex justify-between text-xs text-base-content/40 px-1">
                    <span>0s</span><span>10s</span>
                </div>
            </div>

            <div class="flex flex-col gap-2">
                <div class="flex justify-between items-center">
                    <label class="font-semibold">Expiration</label>
                    <span class="badge badge-secondary" id="label-expiration">5s</span>
                </div>
                <input type="range" id="slider-expiration" min="3" max="15" value="5" step="1" class="range range-secondary" />
                <div class="flex justify-between text-xs text-base-content/40 px-1">
                    <span>3s</span><span>15s</span>
                </div>
            </div>

            <div class="divider my-0"></div>

            <div class="flex justify-between items-center text-sm text-base-content/60">
                <span>Durée d'un cycle</span>
                <span id="cycle-total" class="font-semibold text-base-content">10s</span>
            </div>

            <button id="btn-start" class="btn btn-primary w-full">Commencer</button>
        </div>

        <!-- Exercice animé (caché au départ) -->
        <div id="exercise-panel" class="hidden flex flex-col items-center gap-8">
            <div class="relative flex items-center justify-center" style="width: 220px; height: 220px;">
                <div
                    id="breathing-circle"
                    class="rounded-full bg-primary/20 border-4 border-primary flex items-center justify-center"
                    style="width: 100px; height: 100px;"
                >
                    <div id="breathing-inner" class="rounded-full bg-primary/40" style="width: 50px; height: 50px;"></div>
                </div>
            </div>

            <div class="text-center min-h-20">
                <p id="phase-label" class="text-2xl font-semibold text-primary mb-2">—</p>
                <p id="phase-countdown" class="text-5xl font-bold tabular-nums">—</p>
            </div>

            <div class="flex gap-4">
                <button id="btn-stop" class="btn btn-ghost btn-lg">Arrêter</button>
            </div>
        </div>

        <a href="{{ path('breathing_index') }}" class="link link-hover text-sm text-base-content/50 text-center">
            ← Retour aux exercices
        </a>
    </div>
</div>

<script>
(function () {
    const sliderIn  = document.getElementById('slider-inspiration');
    const sliderAp  = document.getElementById('slider-apnea');
    const sliderEx  = document.getElementById('slider-expiration');
    const labelIn   = document.getElementById('label-inspiration');
    const labelAp   = document.getElementById('label-apnea');
    const labelEx   = document.getElementById('label-expiration');
    const cycleTotal = document.getElementById('cycle-total');

    const configPanel   = document.getElementById('config-panel');
    const exercisePanel = document.getElementById('exercise-panel');

    const circle  = document.getElementById('breathing-circle');
    const inner   = document.getElementById('breathing-inner');
    const phaseLabel     = document.getElementById('phase-label');
    const phaseCountdown = document.getElementById('phase-countdown');
    const btnStart = document.getElementById('btn-start');
    const btnStop  = document.getElementById('btn-stop');

    const SIZE_MIN = 100; const SIZE_MAX = 200;
    const INNER_MIN = 50; const INNER_MAX = 110;

    let timer = null;
    let running = false;

    function updateLabels() {
        labelIn.textContent  = sliderIn.value + 's';
        labelAp.textContent  = sliderAp.value + 's';
        labelEx.textContent  = sliderEx.value + 's';
        const total = parseInt(sliderIn.value) + parseInt(sliderAp.value) + parseInt(sliderEx.value);
        cycleTotal.textContent = total + 's';
    }

    sliderIn.addEventListener('input', updateLabels);
    sliderAp.addEventListener('input', updateLabels);
    sliderEx.addEventListener('input', updateLabels);
    updateLabels();

    function setCircle(size, innerSize, durationSec) {
        const d = durationSec * 1000 + 'ms';
        circle.style.transition = `width ${d} ease-in-out, height ${d} ease-in-out`;
        inner.style.transition   = `width ${d} ease-in-out, height ${d} ease-in-out`;
        circle.style.width  = size + 'px'; circle.style.height = size + 'px';
        inner.style.width   = innerSize + 'px'; inner.style.height  = innerSize + 'px';
    }

    function buildPhases() {
        const phases = [];
        const ins = parseInt(sliderIn.value);
        const ap  = parseInt(sliderAp.value);
        const ex  = parseInt(sliderEx.value);
        phases.push({ label: 'Inspirez',  duration: ins, sizeTo: SIZE_MAX, innerTo: INNER_MAX });
        if (ap > 0) phases.push({ label: 'Retenez', duration: ap, sizeTo: SIZE_MAX, innerTo: INNER_MAX });
        phases.push({ label: 'Expirez',   duration: ex, sizeTo: SIZE_MIN, innerTo: INNER_MIN });
        return phases;
    }

    function runPhase(phases, phaseIndex, onDone) {
        const phase = phases[phaseIndex];
        phaseLabel.textContent = phase.label;
        setCircle(phase.sizeTo, phase.innerTo, phase.duration);
        let remaining = phase.duration;
        phaseCountdown.textContent = remaining;
        timer = setInterval(() => {
            remaining--;
            phaseCountdown.textContent = remaining;
            if (remaining <= 0) { clearInterval(timer); onDone(); }
        }, 1000);
    }

    function runCycle(phases) {
        let i = 0;
        function next() {
            if (!running) return;
            if (i >= phases.length) i = 0;
            runPhase(phases, i, () => { i++; next(); });
        }
        next();
    }

    btnStart.addEventListener('click', () => {
        running = true;
        configPanel.classList.add('hidden');
        exercisePanel.classList.remove('hidden');
        exercisePanel.classList.add('flex');
        runCycle(buildPhases());
    });

    btnStop.addEventListener('click', () => {
        running = false;
        clearInterval(timer);
        exercisePanel.classList.add('hidden');
        exercisePanel.classList.remove('flex');
        configPanel.classList.remove('hidden');
        phaseLabel.textContent = '—';
        phaseCountdown.textContent = '—';
        circle.style.transition = 'width 0.5s ease, height 0.5s ease';
        inner.style.transition  = 'width 0.5s ease, height 0.5s ease';
        circle.style.width = SIZE_MIN + 'px'; circle.style.height = SIZE_MIN + 'px';
        inner.style.width  = INNER_MIN + 'px'; inner.style.height  = INNER_MIN + 'px';
    });
})();
</script>
{% endblock %}
